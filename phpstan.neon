parameters:
    level: 5
    paths:
        - app
    excludePaths:
        - app/Http/Middleware/*
        - app/Exceptions/*
    ignoreErrors:
        # Ignore dynamic property access in Laravel
        - '#Dynamic property access on#'
        # Ignore magic methods
        - '#Call to an undefined method#'
    bootstrapFiles:
        - vendor/autoload.php
